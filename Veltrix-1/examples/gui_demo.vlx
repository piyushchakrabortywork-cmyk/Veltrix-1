window "My First Veltrix App" {
    width: 600,
    height: 400,
    bg: "#00ff1aff",
    resizable: False,
};

rectangle {
    x: 50,
    y: 60,
    width: 250,
    height: 100,
    color: "#ffffffff",
};

circle {
    x: 300,
    y: 100,
    radius: 20,
    color: "#0d00ffff",
};

line {
    x1: 50,
    y1: 200,
    x2: 400,
    y2: 250,
    color: "#5555ff",
    thickness: 5,
};

show window;
